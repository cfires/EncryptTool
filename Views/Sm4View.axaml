<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:EncryptTool.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="EncryptTool.Sm4View"
			 x:DataType="vm:Sm4ViewModel">
	<StackPanel>
		<TextBlock Text="SM4" FontSize="17" FontWeight="Bold"/>

		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="0 5">
			<TextBox
			x:Name="TxtKey"
			Watermark="请输入32位HEX格式密钥"
			Height="40"
			Width="500"
			Text="{Binding Key, Mode=TwoWay}"/>
			<TextBlock
			x:Name="TxtKeyLength"
			Text="{Binding KeyLength, StringFormat='长度：{0}'}"
			VerticalAlignment="Center"
			MinWidth="60"/>
		</StackPanel>

		<TextBox
		x:Name="TxtIV"
		Watermark="偏移量IV（CBC模式必填，32位）"
		Height="40"
		Margin="0 5"
		IsEnabled="{Binding IsIvEnabled}"
		Text="{Binding IV, Mode=TwoWay}"/>

		<StackPanel Orientation="Horizontal" Spacing="15" Margin="0 10">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
				<TextBlock Text="工作模式" VerticalAlignment="Center"/>
				<ComboBox Width="120" Height="32"
						  SelectedItem="{Binding SelectedMode}">
					<ComboBox.Items>
						<x:String>CBC</x:String>
						<x:String>ECB</x:String>
					</ComboBox.Items>
				</ComboBox>
			</StackPanel>

			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
				<TextBlock Text="字符集" VerticalAlignment="Center"/>
				<ComboBox Width="120" Height="32"
						  SelectedItem="{Binding SelectedCharset}">
					<ComboBox.Items>
						<x:String>UTF-8</x:String>
						<x:String>GB2312</x:String>
					</ComboBox.Items>
				</ComboBox>
			</StackPanel>

			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
				<TextBlock Text="输出格式" VerticalAlignment="Center"/>
				<ComboBox Width="120" Height="32"
						  SelectedItem="{Binding SelectedOutputFormat}">
					<ComboBox.Items>
						<x:String>Base64</x:String>
						<x:String>HEX</x:String>
					</ComboBox.Items>
				</ComboBox>
			</StackPanel>
		</StackPanel>

		<TextBox
		Watermark="输入明文"
		Height="120"
		AcceptsReturn="True"
		Text="{Binding Input, Mode=TwoWay}"/>

		<StackPanel Orientation="Horizontal" Margin="0 12" Spacing="12">
			<Button
			Content="加密"
			Command="{Binding EncryptCommand}"
			Width="110"/>
			<Button
			Content="解密"
			Command="{Binding DecryptCommand}"
			Width="110"/>
		</StackPanel>

		<TextBox
		Watermark="输出结果"
		Height="140"
		AcceptsReturn="True"
		Text="{Binding Output, Mode=OneWay}"
		IsReadOnly="True"/>
	</StackPanel>
</UserControl>
